<div class="container container--narrow">
  <div class="page-header">
    <h1 class="page-header__title">My Bookings</h1>
    <p class="page-header__sub">Enter your email to view all your event registrations.</p>
  </div>

  <div class="lookup-box">
    <form action="/registrations" method="GET" class="form">
      <div class="form__group">
        <label class="label" for="email">Email Address</label>
        <input type="email" id="email" name="email" class="input input--lg" required placeholder="jane@example.com" />
      </div>
      <button type="submit" class="btn btn--primary btn--full">Find My Bookings</button>
    </form>
  </div>
</div>

