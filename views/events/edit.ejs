<div class="container container--narrow">
  <a href="/events/<%= event.id %>" class="back-link">← Back to Event</a>
  <h1 class="page-header__title">Edit Event</h1>

  <% if (errors.length > 0) { %>
    <div class="error-list">
      <% errors.forEach(e => { %><p>× <%= e.msg %></p><% }) %>
    </div>
  <% } %>

  <form action="/events/<%= event.id %>?_method=PUT" method="POST" class="form form--card" novalidate>
    <div class="form__section">
      <h2 class="form__section-title">Event Details</h2>
      <div class="form__group">
        <label class="label" for="title">Event Title <span class="label__req">*</span></label>
        <input type="text" id="title" name="title" class="input" value="<%= old.title || '' %>" required />
      </div>
      <div class="form__group">
        <label class="label" for="description">Description</label>
        <textarea id="description" name="description" class="input input--textarea" rows="4"><%= old.description || '' %></textarea>
      </div>
      <div class="form__row">
        <div class="form__group">
          <label class="label" for="category">Category <span class="label__req">*</span></label>
          <select id="category" name="category" class="select">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= old.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="form__group">
          <label class="label" for="organizer">Organizer <span class="label__req">*</span></label>
          <input type="text" id="organizer" name="organizer" class="input" value="<%= old.organizer || '' %>" required />
        </div>
      </div>
    </div>

    <div class="form__section">
      <h2 class="form__section-title">When & Where</h2>
      <div class="form__row">
        <div class="form__group">
          <label class="label" for="event_date">Date & Time <span class="label__req">*</span></label>
          <input type="datetime-local" id="event_date" name="event_date" class="input"
            value="<%= new Date(old.event_date).toISOString().slice(0,16) %>" required />
        </div>
        <div class="form__group">
          <label class="label" for="location">Location <span class="label__req">*</span></label>
          <input type="text" id="location" name="location" class="input" value="<%= old.location || '' %>" required />
        </div>
      </div>
    </div>

    <div class="form__section">
      <h2 class="form__section-title">Capacity & Pricing</h2>
      <div class="form__row">
        <div class="form__group">
          <label class="label" for="capacity">Max Capacity <span class="label__req">*</span></label>
          <input type="number" id="capacity" name="capacity" class="input" value="<%= old.capacity %>" required min="1" />
        </div>
        <div class="form__group">
          <label class="label" for="price">Ticket Price (€)</label>
          <input type="number" id="price" name="price" class="input" value="<%= old.price %>" required min="0" step="0.01" />
        </div>
      </div>
    </div>

    <div class="form__actions">
      <a href="/events/<%= event.id %>" class="btn btn--ghost">Cancel</a>
      <button type="submit" class="btn btn--primary">Save Changes</button>
    </div>
  </form>
</div>

